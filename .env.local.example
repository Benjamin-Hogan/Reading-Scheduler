# Copy to .env.local and fill in values from Google Cloud Console.
# Setup guide: docs/google-cloud-setup.md

# Google Books API — book search (recommended; avoids low anonymous quotas)
GOOGLE_BOOKS_API_KEY=

# Google Calendar OAuth — calendar export
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Leave unset so OAuth uses whatever origin you open the app from (localhost, LAN IP, tunnel).
# Only set this if you need a single fixed callback (e.g. production deploy).
# GOOGLE_REDIRECT_URI=

# Optional: persistent directory for ICS subscription feeds (self-hosted / Docker)
# FEED_DATA_DIR=.feed-data
