# Copy to .env before: docker compose up -d
# See docs/self-hosting.md and docs/google-cloud-setup.md

# Host port published on your machine (compose maps ${PORT}:3000)
PORT=3000

# Google Books API — recommended for book search
GOOGLE_BOOKS_API_KEY=

# Google Calendar OAuth — required for calendar export and cloud sync sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required in production — generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional: force a fixed OAuth callback when behind a reverse proxy.
# Example: https://reading.example.com/api/auth/google/callback
# Leave unset to derive from the incoming request Host header (requires proxy to forward Host / X-Forwarded-*).
# GOOGLE_REDIRECT_URI=
